{
  "extends": "@arch/tsconfig/tsconfig.node.json",
  "include": [
    "index.ts",
    "domains/**/*",
  ],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "strictPropertyInitialization": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "types": [
      "electron-vite/node",
      "better-sqlite3",
    ],
    "baseUrl": ".",
    "paths": {
      "@domains/App/*": ["domains/App/*/public-api.ts"],
      "@domains/Settings/*": ["domains/Settings/*/public-api.ts"],
      "@domains/Sources/*": ["domains/Sources/*/public-api.ts"],
      "@domains/Tasks/*": ["domains/Tasks/*/public-api.ts"],
      "@domains/Shared/*": ["domains/Shared/*/public-api.ts"]
    }
  }
}